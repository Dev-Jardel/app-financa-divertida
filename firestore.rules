rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Define o seu ID de Projeto REAL (projectId) aqui.
    // O valor {appId} deve ser substituído pelo SEU projectId do Passo 5.
    // Se o seu projectId for 'family-finance-123', o caminho será 
    // /artifacts/family-finance-123/public/data/{document=**}

    match /artifacts/{appId}/public/data/{document=**} {
      allow read, write: if request.auth != null;
    }

    // Permite que usuários leiam e escrevam dados públicos APENAS se estiverem autenticados (mesmo que anonimamente).
  }
}